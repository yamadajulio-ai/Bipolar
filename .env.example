# Segredo para criptografia de sessão (mínimo 32 caracteres)
SESSION_SECRET=troque-por-uma-string-segura-de-pelo-menos-32-caracteres

# URL do banco de dados
# SQLite (desenvolvimento):
DATABASE_URL="file:./dev.db"
# PostgreSQL (produção):
# DATABASE_URL="postgresql://user:password@localhost:5432/empresa_bipolar"

# Google OAuth (para login com Google e integração Calendar)
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:3000/api/auth/google-login/callback

# Chave para criptografia de tokens OAuth (64 caracteres hexadecimais = 32 bytes)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=gere-uma-chave-hex-de-64-caracteres

# Google Cloud Translation API (para tradução de artigos PubMed EN→PT-BR)
# Crie em: https://console.cloud.google.com/apis/credentials
# Ative: Cloud Translation API (Basic) — 500k chars/mês grátis
GOOGLE_TRANSLATE_API_KEY=sua-api-key

# Sentry (monitoramento de erros)
NEXT_PUBLIC_SENTRY_DSN=https://seu-dsn@sentry.io/projeto

# Vercel Cron (autenticação de cron jobs)
CRON_SECRET=gere-um-segredo-forte

# Anthropic Claude (chatbot SOS de crise)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI GPT-5.4 (narrativa de insights)
OPENAI_API_KEY=sk-...
# Modelo da narrativa (default: gpt-5.4, permite canário com gpt-5.2)
# OPENAI_NARRATIVE_MODEL=gpt-5.4

# Web Push (VAPID keys — gere com: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=sua-chave-publica-vapid
VAPID_PRIVATE_KEY=sua-chave-privada-vapid
# VAPID_SUBJECT=mailto:contato@suportebipolar.com

# SOS HMAC (autenticação do chatbot de crise)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SOS_HMAC_KEY=gere-um-hmac-hex-de-64-caracteres

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# WhatsApp Business (Cloud API)
# WHATSAPP_TOKEN=seu-token-permanente
# WHATSAPP_PHONE_NUMBER_ID=seu-phone-number-id
# WHATSAPP_VERIFY_TOKEN=seu-verify-token
# WHATSAPP_APP_SECRET=seu-app-secret

# Meta Pixel + Conversions API
# NEXT_PUBLIC_META_PIXEL_ID=seu-pixel-id
# META_PIXEL_ID=seu-pixel-id
# META_CAPI_ACCESS_TOKEN=seu-access-token

# Microsoft Clarity
# NEXT_PUBLIC_CLARITY_ID=seu-clarity-id

# Google Gemini (geração de imagens)
# GOOGLE_GENAI_API_KEY=sua-api-key

# URL pública do app
# NEXT_PUBLIC_APP_URL=https://suportebipolar.com

# Feature flags (descomente para desativar)
# KILL_SNAPSHOTS=1
# KILL_AI_NARRATIVE=1
# KILL_PROFESSIONAL_SHARING=1
# KILL_PUSH_NOTIFICATIONS=1
