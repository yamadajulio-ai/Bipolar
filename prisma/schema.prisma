generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(uuid())
  email            String             @unique
  passwordHash     String?
  authProvider     String             @default("email")
  googleSub        String?            @unique
  name             String?
  role             String             @default("user") // "user" | "admin"
  onboarded        Boolean            @default(false)
  onboardingGoal   String?
  createdAt        DateTime           @default(now())
  entries          DiaryEntry[]
  views            ContentView[]
  sleepLogs        SleepLog[]
  exerciseSessions ExerciseSession[]
  dailyRhythms     DailyRhythm[]
  reminderSettings ReminderSettings?
  crisisPlan       CrisisPlan?
  courseProgress    CourseProgress[]
  plannerBlocks    PlannerBlock[]
  stabilityRule    StabilityRule?
  googleAccount         GoogleAccount?
  integrationKeys       IntegrationKey[]
  healthMetrics         HealthMetric[]
  financialTransactions FinancialTransaction[]
  alertFeedbacks        AlertFeedback[]
  sosEvents             SOSEvent[]
  socioeconomicProfile  SocioeconomicProfile?
  professionalAccesses  ProfessionalAccess[]
  consents              Consent[]
  weeklyAssessments     WeeklyAssessment[]
  lifeChartEvents       LifeChartEvent[]
  functioningAssessments FunctioningAssessment[]
  cognitiveTests         CognitiveTest[]
  pushSubscriptions      PushSubscription[]
  feedbacks              Feedback[]
  contextualFeedbacks    ContextualFeedback[]
  journalEntries         JournalEntry[]
  narratives             Narrative[]
  communicationPreference CommunicationPreference?
  messageLogs            MessageLog[]
}

model DiaryEntry {
  id             String   @id @default(uuid())
  userId         String
  date           String   // YYYY-MM-DD
  mood           Int      // 1..5
  sleepHours     Float    // 0..24
  note           String?  // max 280 chars
  energyLevel    Int?     // 1..5 (1=letargico, 5=agitado)
  anxietyLevel   Int?     // 1..5
  irritability   Int?     // 1..5
  tookMedication String?  // "sim" | "nao" | "nao_sei"
  warningSigns   String?  // JSON array of selected warning sign keys
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@unique([userId, date])
}

model ContentView {
  id       String   @id @default(uuid())
  userId   String
  slug     String
  viewedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SleepLog {
  id         String   @id @default(uuid())
  userId     String
  date       String   // YYYY-MM-DD (morning date)
  bedtime    String   // HH:MM
  wakeTime   String   // HH:MM
  totalHours Float
  quality    Int      // 0..100
  awakenings Int      @default(0)
  hrv        Int?     // Heart Rate Variability (ms) — ex: RMSSD from wearable
  heartRate  Int?     // Resting heart rate (bpm) during sleep
  excluded   Boolean  @default(false) // Incomplete/unreliable record — excluded from metrics
  preRoutine String?  // JSON array of routine keys
  notes      String?  // max 280 chars
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, date])
}

model ExerciseSession {
  id           String   @id @default(uuid())
  userId       String
  exerciseType String   // "respiracao_478" | "respiracao_box" | "respiracao_diafragmatica" | "aterramento_5sentidos" | "aterramento_muscular"
  durationSecs Int
  completedAt  DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([completedAt])
}

model DailyRhythm {
  id                String   @id @default(uuid())
  userId            String
  date              String   // YYYY-MM-DD
  wakeTime          String?  // HH:MM
  firstContact      String?  // HH:MM
  mainActivityStart String?  // HH:MM
  dinnerTime        String?  // HH:MM
  bedtime           String?  // HH:MM
  notes             String?  // max 280 chars
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, date])
}

model ReminderSettings {
  id                String  @id @default(uuid())
  userId            String  @unique
  wakeReminder      String? // HH:MM
  sleepReminder     String? // HH:MM
  diaryReminder     String? // HH:MM
  breathingReminder String? // HH:MM
  enabled           Boolean @default(true)
  privacyMode       Boolean @default(false) // Generic notification text (hides health content on lock screen)
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CrisisPlan {
  id                String   @id @default(uuid())
  userId            String   @unique
  trustedContacts   String?  // JSON array of { name, phone }
  professionalName  String?
  professionalPhone String?
  medications       String?  // JSON array of medication names only
  preferredHospital String?
  copingStrategies  String?  // JSON array of strings
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CourseProgress {
  id          String   @id @default(uuid())
  userId      String
  courseSlug   String
  lessonSlug  String
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseSlug, lessonSlug])
  @@index([userId])
}

// ── Planner (Calendário de Estabilidade) ───────────────────────────

model PlannerBlock {
  id          String   @id @default(uuid())
  userId      String
  title       String
  category    String   // "sono", "medicacao", "refeicao", "trabalho", "social", "exercicio", "lazer", "outro"
  kind        String   @default("FLEX") // "ANCHOR" | "FLEX" | "RISK"
  isRoutine   Boolean  @default(false)
  startAt     DateTime
  endAt       DateTime
  notes       String?
  energyCost  Int      @default(3)  // 0..10
  stimulation   Int      @default(1)  // 0=LOW, 1=MED, 2=HIGH
  googleEventId String?
  googleColor   String?              // Google Calendar colorId (1-11)
  sourceType    String   @default("app") // "app" | "google"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  recurrence  PlannerRecurrence?
  exceptions  PlannerException[]

  @@index([userId, startAt])
  @@index([userId, endAt])
  @@unique([userId, googleEventId])
}

model PlannerRecurrence {
  id        String   @id @default(uuid())
  blockId   String   @unique
  freq      String   // "NONE" | "DAILY" | "WEEKLY"
  interval  Int      @default(1)
  weekDays  String?  // "1,3,5" (0=Dom..6=Sab) when WEEKLY
  until     DateTime?
  createdAt DateTime @default(now())

  block     PlannerBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
}

model PlannerException {
  id              String    @id @default(uuid())
  blockId         String
  occurrenceDate  DateTime
  isCancelled     Boolean   @default(false)
  overrideStartAt DateTime?
  overrideEndAt   DateTime?
  overrideTitle   String?
  overrideNotes   String?
  createdAt       DateTime  @default(now())

  block           PlannerBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@unique([blockId, occurrenceDate])
}

model StabilityRule {
  id                   String   @id @default(uuid())
  userId               String   @unique
  lateEventCutoffMin   Int      @default(1260) // 21:00 = 21*60
  windDownMin          Int      @default(90)
  minBufferBeforeSleep Int      @default(60)
  maxLateNightsPerWeek Int      @default(2)
  protectAnchors       Boolean  @default(true)
  targetSleepTimeMin   Int?     // minutes since 00:00 (e.g. 1380 = 23:00)
  targetWakeTimeMin    Int?     // minutes since 00:00 (e.g. 420 = 07:00)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Integracoes Externas ────────────────────────────────────────

model GoogleAccount {
  id           String    @id @default(uuid())
  userId       String    @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  calendarId   String    @default("primary")
  syncToken    String?
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IntegrationKey {
  id               String   @id @default(uuid())
  userId           String
  service          String   // "health_auto_export"
  apiKey           String   @unique
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  lastPayloadDebug String?  // Last raw payload sample for debugging

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, service])
}

// ── Métricas genéricas de saúde (Health Auto Export) ─────────────

model HealthMetric {
  id        String   @id @default(uuid())
  userId    String
  date      String   // YYYY-MM-DD
  metric    String   // "steps", "active_calories", "blood_oxygen"
  value     Float
  unit      String   // "count", "kcal", "%"
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, metric])
  @@index([userId, date])
}

// ── Notícias (cache global) ──────────────────────────────────────

model NewsArticle {
  id          String   @id @default(uuid())
  externalId  String   @unique
  source      String   // "pubmed" | "google_news"
  title       String
  url         String
  publishedAt DateTime
  sourceName  String?
  authors     String?
  fetchedAt   DateTime @default(now())

  @@index([source])
  @@index([publishedAt])
}

// ── Rate Limiting ───────────────────────────────────────────────────

model RateLimit {
  id        String   @id @default(uuid())
  key       String   // e.g. "login:192.168.1.1"
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([key, expiresAt])
}

// ── Financeiro ──────────────────────────────────────────────────

model ProfessionalAccess {
  id                String    @id @default(uuid())
  userId            String
  token             String    @unique     // URL-safe random token
  pinHash           String                // bcrypt hash of 6-digit PIN
  label             String?               // e.g. "Dr. Silva"
  expiresAt         DateTime
  consentGivenAt    DateTime  @default(now())
  revokedAt         DateTime?
  lastAccessedAt    DateTime?
  failedPinAttempts Int       @default(0)
  lockedUntil       DateTime?
  shareSosEvents    Boolean   @default(false)
  createdAt         DateTime  @default(now())

  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessLogs        AccessLog[]

  @@index([userId])
  @@index([token])
}

model AccessLog {
  id        String   @id @default(uuid())
  accessId  String
  action    String   // "pin_validated" | "data_viewed" | "pin_failed" | "locked"
  ip        String?
  createdAt DateTime @default(now())

  access    ProfessionalAccess @relation(fields: [accessId], references: [id], onDelete: Cascade)

  @@index([accessId, createdAt])
}

model SocioeconomicProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  careAccess          String   // "regular" | "irregular" | "sem_acesso"
  medicationSource    String   // "sus" | "plano" | "particular" | "nao_toma"
  consultFrequency    String   // "mensal" | "trimestral" | "semestral" | "quando_consigo" | "nunca"
  hasEmergencyContact Boolean  @default(false)
  livingSituation     String?  // "estavel" | "instavel" | "situacao_rua"
  updatedAt           DateTime @updatedAt

  user                User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SOSEvent {
  id        String   @id @default(uuid())
  userId    String
  action    String   // "opened" | "called_188" | "called_192" | "called_contact" | "breathing" | "grounding"
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model FinancialTransaction {
  id          String    @id @default(uuid())
  userId      String
  date        String    // YYYY-MM-DD
  description String
  amount      Float     // positivo = receita, negativo = despesa
  category    String
  account     String?
  source      String    @default("manual") // "manual" | "mobills_csv"
  occurredAt  DateTime? // horário real da transação (para detectar gastos noturnos)
  createdAt   DateTime  @default(now())

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@unique([userId, date, description, amount])
}

model AlertFeedback {
  id        String   @id @default(uuid())
  userId    String
  alertType String   // "spending_spike" | "frequency_spike" | "sustained_increase"
  alertDate String   // YYYY-MM-DD
  useful    Boolean
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, alertType, alertDate])
  @@index([userId])
}

// ── Admin Audit Log ─────────────────────────────────────────────

model AdminAuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String   // "view_feedbacks" | "reveal_email" | "filter_priority"
  metadata  String?  // JSON: { feedbackId, filters, etc. }
  ip        String?  // masked /24
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action])
}

// ── Feedback do Usuário ──────────────────────────────────────────

model Feedback {
  id         String   @id @default(uuid())
  userId     String
  category   String   // "suggestion" | "bug" | "praise" | "other"
  message    String
  screen     String?  // tela relacionada (opcional)
  canContact Boolean  @default(false)
  priority   String   @default("normal") // "normal" | "high" (crise detectada)
  route      String?  // rota atual do usuário
  appVersion String?  // versão do build
  clientType String?  // "pwa" | "safari" | "chrome"
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([category])
  @@index([priority])
}

model ContextualFeedback {
  id         String   @id @default(uuid())
  userId     String
  contextKey String   // "insight:2026-03-18" | "content:abc123" | "report:2026-03"
  useful     Boolean
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contextKey])
  @@index([contextKey])
}

// ── LGPD — Consentimentos ─────────────────────────────────────────

model Consent {
  id        String   @id @default(uuid())
  userId    String
  scope     String   // "health_data" | "terms_of_use" | "ai_narrative" | "push_notifications" | "email_notifications" | "whatsapp" | "professional_sharing"
  version   Int      @default(1) // consent policy version — bump when terms change
  grantedAt DateTime @default(now())
  revokedAt DateTime?
  ipAddress String?  // masked /24

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scope])
}

// ── Avaliação Semanal (ASRM + PHQ-9 + FAST) ─────────────────────

model WeeklyAssessment {
  id              String   @id @default(uuid())
  userId          String
  date            String   // YYYY-MM-DD (week ending date)
  asrmScores      String?  // JSON: [0-4, 0-4, 0-4, 0-4, 0-4]
  asrmTotal       Int?     // 0-20 (>=6 suggests hypomania)
  phq9Scores      String?  // JSON: [0-3, 0-3, ..., 0-3] (9 items)
  phq9Total       Int?     // 0-27
  phq9Item9       Int?     // Item 9 (ideation) separated for safety flow
  fastScores      String?  // JSON: { work: 1-5, social: 1-5, ... }
  fastAvg         Float?   // Average functioning score
  notes           String?  // max 280 chars
  createdAt       DateTime @default(now())

  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

// ── Life Chart Events (marcadores de eventos significativos) ──────

model LifeChartEvent {
  id        String   @id @default(uuid())
  userId    String
  date      String   // YYYY-MM-DD
  eventType String   // "med_change" | "stressor" | "travel" | "hospitalization" | "therapy" | "menstrual" | "other"
  label     String   // Brief description
  notes     String?
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

// ── Avaliação de Funcionamento (FAST short) ──────────────────────

model FunctioningAssessment {
  id          String   @id @default(uuid())
  userId      String
  date        String   // YYYY-MM-DD
  work        Int?     // 1-5 (1=muito difícil, 5=sem dificuldade)
  social      Int?     // 1-5
  selfcare    Int?     // 1-5
  finances    Int?     // 1-5
  cognition   Int?     // 1-5
  leisure     Int?     // 1-5
  avgScore    Float?
  createdAt   DateTime @default(now())

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

// ── Push Subscriptions (Web Push) ────────────────────────────────

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String
  p256dh    String   // Base64-encoded P-256 public key
  auth      String   // Base64-encoded auth secret
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@unique([endpoint])        // Global: one endpoint → one user (DB-enforced)
  @@index([userId])
}

// ── AI Narrative (persistência + feedback) ──────────────────────

model Narrative {
  id                    String              @id @default(uuid())
  userId                String
  createdAt             DateTime            @default(now())

  periodStart           String              // YYYY-MM-DD
  periodEnd             String              // YYYY-MM-DD

  status                String              @default("completed") // completed | failed | fallback
  riskLevel             String              // low | moderate | high
  dataQuality           String              // ok | limited | insufficient

  model                 String              // e.g. "gpt-5.4"
  reasoningEffort       String              // low | medium | high
  promptVersion         String              // e.g. "v2"
  schemaVersion         String              // e.g. "narrative_v2"
  analyticsVersion      String?             // computeInsights version
  guardrailVersion      String?             // forbidden patterns version

  sourceFingerprint     String              // SHA-256 hash of deterministic input snapshot
  outputJson            Json                // Full NarrativeResultV2
  renderedText          String?             @db.Text // Flattened text for search/display

  shareWithProfessional Boolean             @default(false)
  bypassLlm             Boolean             @default(false)
  bypassReason          String?
  llmAttempted          Boolean             @default(false)

  guardrailPassed       Boolean             @default(true)
  guardrailViolations   String[]            // Array of violation descriptions

  inputTokens           Int?
  cachedInputTokens     Int?
  outputTokens          Int?
  reasoningTokens       Int?
  latencyMs             Int?

  previousNarrativeId   String?

  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedbacks             NarrativeFeedback[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, sourceFingerprint])
}

model NarrativeFeedback {
  id           String   @id @default(uuid())
  narrativeId  String
  createdAt    DateTime @default(now())

  rating       String   // useful | not_useful
  reasonCodes  String[] // e.g. ["too_generic", "inaccurate", "too_long"]
  comment      String?  @db.Text

  narrative    Narrative @relation(fields: [narrativeId], references: [id], onDelete: Cascade)

  @@index([narrativeId, createdAt(sort: Desc)])
}

// ── Testes Cognitivos ────────────────────────────────────────────

model CognitiveTest {
  id             String   @id @default(uuid())
  userId         String
  reactionTimeMs Int?     // Median of 5 trials (ms)
  digitSpan      Int?     // Max span reached
  createdAt      DateTime @default(now())

  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ── Diário Pessoal + Insights Rápidos ──────────────────────────

enum JournalType {
  DIARY
  QUICK_INSIGHT
}

enum SnapshotSource {
  RECENT_CHECKIN  // Auto-captured from recent check-in (< 4h)
  NONE            // No mood data available at time of entry
}

model JournalEntry {
  id                String         @id @default(uuid())
  userId            String
  type              JournalType
  content           String         // Plain text only — max 5000 (diary) or 280 (insight)
  // ── Immutable mood snapshot at time of entry ──
  maniaScore        Int?           // 0-100 mania axis
  depressionScore   Int?           // 0-100 depression axis
  energyScore       Int?           // 1-5 from check-in
  zoneAtCapture     String?        // "depressao"|"depressao_leve"|"eutimia"|"hipomania"|"mania"
  mixedAtCapture    Boolean?       // Was mixed features detected?
  moodModelVersion  String         @default("v1") // Tracks threshold/EWMA changes
  snapshotSource    SnapshotSource @default(NONE)
  sourceCheckInId   String?        // Optional FK to DiaryEntry for provenance
  // ── Temporal context ──
  entryDateLocal    String         // YYYY-MM-DD in user's timezone
  timezone          String         @default("America/Sao_Paulo")
  capturedAt        DateTime       @default(now()) // When mood snapshot was taken
  // ── Consent & edit tracking ──
  aiUseAllowed      Boolean        @default(false) // Explicit opt-in for AI narrative use
  editedAt          DateTime?      // Set on any edit (no version history in P0)
  // ── Idempotency ──
  idempotencyKey    String?        @unique // Client-generated key to prevent duplicate entries
  createdAt         DateTime       @default(now())

  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, entryDateLocal])
  @@index([userId, type])
}

// ── Communication Preferences (reactivation, email, WhatsApp) ───

model CommunicationPreference {
  id        String   @id @default(uuid())
  userId    String   @unique
  push      Boolean  @default(true)
  email     Boolean  @default(false)
  whatsapp  Boolean  @default(false)
  quietStart String? // HH:MM — start of quiet hours (no push)
  quietEnd   String? // HH:MM — end of quiet hours
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Message Log (idempotency for reactivation & comms) ──────────

model MessageLog {
  id        String   @id @default(uuid())
  userId    String
  channel   String   // "push" | "email" | "whatsapp"
  category  String   // "reactivation" | "reminder" | "weekly_summary"
  tier      String?  // "24h" | "72h" | "7d" (for reactivation)
  sentAt    DateTime @default(now())
  delivered Boolean  @default(false)

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category, sentAt(sort: Desc)])
  @@index([userId, channel, sentAt(sort: Desc)])
}
